# Copy to .env.local and fill in. .env.local is gitignored.
# Restart `npm run dev` after changing env vars.

# Claude API — captions. Without it, the app falls back to template captions.
# Get one at https://console.anthropic.com → API keys. Server-only.
ANTHROPIC_API_KEY=

# Supabase — Postgres + Storage for the Image Library.
# Project → Settings → API:
#   SUPABASE_URL = the "Project URL"
#   SUPABASE_SERVICE_ROLE_KEY = the "service_role" secret (server-only, NEVER ship to client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google sign-in (Supabase Auth). The app requires login only once the anon key
# is set — set it AFTER enabling the Google provider in Supabase, or you lock
# yourself out. Anon key: Supabase → Settings → API → "anon public".
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Comma-separated list of emails allowed to sign in.
ADMIN_EMAILS=

# Not needed: DATABASE_URL (all DB access is via the service role)
